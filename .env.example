# ── Supabase ─────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-role-key   # never expose this on frontend

# ── Anthropic ─────────────────────────────────────────────────
ANTHROPIC_API_KEY=your-anthropic-key

# ── App ───────────────────────────────────────────────────────
APP_ENV=development                          # development | production
FRONTEND_URL=http://localhost:5173           # update to Vercel URL in prod
